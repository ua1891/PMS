generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id             String   @id @default(uuid())
  trackingNumber String   @unique
  customerName   String
  customerPhone  String?
  customerEmail  String?
  destination    String?
  status         String   @default("Pending") // Pending, In Transit, Pickup Ready, Returned, Delivered
  statusDetails  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  alerts         Alert[]
}

model Alert {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  type      String // e.g. "Pickup Ready", "Return Initiated", "Delivery Confirmed", "Delayed Shipment"
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
